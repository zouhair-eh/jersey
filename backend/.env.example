# Environment Variables for jersey_marocco Backend
# Copy this file to .env and fill in the values.

# ── MongoDB ────────────────────────────────────────────────────────────────
MONGODB_URI=mongodb+srv://<user>:<password>@cluster.mongodb.net/jersey_marocco?retryWrites=true&w=majority

# ── JWT ────────────────────────────────────────────────────────────────────
JWT_SECRET=replace_with_a_long_random_secret
JWT_EXPIRES_IN=7d

# ── App ────────────────────────────────────────────────────────────────────
NODE_ENV=development
PORT=5000

# ── Cloud Storage (Cloudinary example) ────────────────────────────────────
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=
